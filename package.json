{
  "name": "deepagents-app-workspace",
  "version": "0.2.10",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "pnpm@9.15.5",
  "scripts": {
    "build": "pnpm --filter deepagents-app-ts build && pnpm --filter nuwax-flow-ts build && pnpm --filter inspector build",
    "test": "pnpm --filter deepagents-app-ts test && pnpm --filter nuwax-flow-ts test && pnpm --filter inspector test",
    "dev": "pnpm --filter deepagents-app-ts dev",
    "typecheck": "pnpm --filter deepagents-app-ts typecheck && pnpm --filter nuwax-flow-ts typecheck",
    "flow:build": "pnpm --filter nuwax-flow-ts build",
    "flow:test": "pnpm --filter nuwax-flow-ts test",
    "flow:typecheck": "pnpm --filter nuwax-flow-ts typecheck",
    "flow:graph": "pnpm --filter nuwax-flow-ts graph",
    "dev-agent-flow:static": "pnpm --filter @deepagents/dev-agent-flow-config iteration:static",
    "graph": "pnpm --filter deepagents-app-ts graph",
    "inspect": "pnpm --filter inspector inspect --",
    "pack": "node scripts/pack-template.js all",
    "pack:ts": "node scripts/pack-template.js ts",
    "pack:flow-ts": "node scripts/pack-template.js flow-ts",
    "pack:py": "node scripts/pack-template.js py",
    "pack:all": "node scripts/pack-template.js all",
    "pack:release": "node scripts/pack-template.js all --release",
    "dev:electron": "node scripts/dev-electron-workspace.mjs",
    "dev:electron:link": "node scripts/dev-electron-workspace.mjs link",
    "dev:electron:sync": "node scripts/dev-electron-workspace.mjs sync",
    "dev:electron:status": "node scripts/dev-electron-workspace.mjs status",
    "dev:electron:unlink": "node scripts/dev-electron-workspace.mjs unlink"
  },
  "description": "DeepAgents development templates — monorepo for agent template and dev-agent config",
  "license": "MIT"
}
