# ===========================================
# DeepAgents Dev Templates - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# --- Model Credentials (pick ONE protocol family) ---
# This agent supports BOTH the Anthropic protocol and the OpenAI (chat) protocol,
# including third-party compatible endpoints (DeepSeek, Moonshot, Zhipu GLM,
# rcoder/ccvibe-style relays, bigmodel's /anthropic, etc.). Fill in the family you
# use and leave the other blank. Protocol selection is auto-detected from which
# credential vars are present — see LLM_PROVIDER below to force it.
#
# Anthropic protocol / Anthropic-compatible proxy:
#   - For token-based proxies (e.g. bigmodel /anthropic), set AUTH_TOKEN and leave
#     API_KEY EMPTY. If API_KEY is also set, the launcher deletes AUTH_TOKEN
#     (API key wins) — so token auth requires API_KEY to be unset.
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
# OpenAI protocol / OpenAI-compatible third-party endpoint:
OPENAI_API_KEY=

# --- Model Configuration (per protocol family) ---
# ANTHROPIC_* and OPENAI_* map to the SAME config fields (model.name / model.baseUrl).
# Set only the family matching your credentials above.
ANTHROPIC_MODEL=
ANTHROPIC_BASE_URL=
# e.g. OPENAI_BASE_URL=https://api.deepseek.com/v1 , OPENAI_MODEL=deepseek-chat
OPENAI_MODEL=
OPENAI_BASE_URL=

# --- Provider Selection ---
# Optional: force a protocol when both families carry signals at once.
#   - unset     : auto-detect from credential vars; if BOTH families are present
#                 AND OPENAI_API_KEY is set, the OpenAI path wins the tie.
#   - anthropic : force Anthropic protocol
#   - openai    : force OpenAI protocol
LLM_PROVIDER=

# --- Model Runtime ---
# Max output tokens per model call (optional).
MAX_TOKENS=

# --- Platform Configuration ---
# Nuwax platform API endpoint
PLATFORM_API_BASE_URL=https://api.nuwax.com
# Platform authentication token
PLATFORM_API_TOKEN=
# Agent and space identifiers
PLATFORM_AGENT_ID=
PLATFORM_SPACE_ID=

# --- ACP Server Configuration ---
# Agent name displayed in ACP clients
ACP_AGENT_NAME=my-scenario-agent
# Agent description
ACP_AGENT_DESCRIPTION=AI agent for [specific scenario]
# Enable debug mode (true/false)
ACP_DEBUG=false
# Workspace root directory (defaults to cwd)
# ACP_WORKSPACE_ROOT=

# --- MCP Configuration ---
# Path to additional MCP config file
# MCP_CONFIG_PATH=./config/mcp.custom.json

# --- ACP Startup Session Configuration ---
# Optional JSON supplied by nuwaclaw/platform at process launch.
# ACP_SESSION_CONFIG_JSON={"model":"claude-sonnet-4-6","agentId":"...","spaceId":"...","systemPrompt":"..."}

# --- Logging ---
# Log level: debug, info, warn, error
LOG_LEVEL=info
