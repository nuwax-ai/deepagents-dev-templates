{
  "model": {
    "provider": "openai",
    "name": "mimo-v2.5-pro",
    "baseUrl": "https://token-plan-cn.xiaomimimo.com/v1"
  },
  "rag": {
    "enabled": true,
    "retrievalTools": ["context7", "howtocook-mcp"],
    "rewrite": {
      "maxKeywords": 5,
      "intentCategories": ["factual", "how_to", "comparison", "latest", "explain"]
    },
    "retrieve": {
      "maxResults": 10,
      "timeout_ms": 10000,
      "retryCount": 1
    },
    "prepare": {
      "maxContextTokens": 4000,
      "deduplication": true,
      "sortByRelevance": true
    },
    "agent": {
      "streaming": true,
      "includeSources": true,
      "confidenceThreshold": 0.5
    }
  },
  "mcp": {
    "servers": {
      "howtocook-mcp": {
        "command": "npx",
        "args": ["-y", "howtocook-mcp"],
        "enabled": true
      },
      "context7": {
        "command": "npx",
        "args": ["-y", "@upstash/context7-mcp"],
        "enabled": true
      }
    }
  }
}
