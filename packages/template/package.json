{
  "name": "deepagents-dev-templates",
  "version": "0.2.10",
  "description": "DeepAgents application agent framework — run AI agents in the terminal (REPL/one-shot) or as an ACP server for nuwaclaw/Zed. Built on deepagents + LangGraph.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "deepagents-app": "dist/index.js"
  },
  "scripts": {
    "build": "npm run codegen:config-schema && tsc && tsc-alias",
    "dev": "tsx watch --tsconfig tsconfig.json src/index.ts",
    "dev:repl": "tsx watch --tsconfig tsconfig.json src/index.ts chat",
    "dev:once": "tsx --tsconfig tsconfig.json src/index.ts",
    "start": "node dist/index.js",
    "start:acp": "tsx src/index.ts",
    "chat": "tsx src/index.ts chat",
    "ask": "tsx src/index.ts ask",
    "run": "tsx src/index.ts run",
    "graph": "node dist/index.js graph",
    "codegen:config-schema": "tsx scripts/codegen-config-schema.ts",
    "new:tool": "tsx scripts/scaffold/tool.ts",
    "new:skill": "tsx scripts/scaffold/skill.ts",
    "new:prompt": "tsx scripts/scaffold/prompt.ts",
    "bundle": "bash scripts/bundle.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:acp-smoke": "vitest run tests/acp-smoke",
    "test:bundle-smoke": "npm run bundle && BUNDLE_SMOKE=1 vitest run tests/bundle-smoke",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/",
    "package": "bash scripts/package.sh",
    "package:all": "bash scripts/package.sh --format all",
    "package:nuwax": "bash scripts/package.sh --format all",
    "package:platforms": "bash scripts/package-platforms.sh",
    "validate:package": "bash scripts/validate-package.sh",
    "inspect": "npm run inspect -w inspector --"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "latest",
    "@langchain/langgraph": "latest",
    "@langchain/openai": "^1.3.0",
    "deepagents": "^1.10.2",
    "deepagents-acp": "latest",
    "dotenv": "^16.4.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^2.0.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "config",
    "prompts",
    "skills",
    "docs",
    "scripts",
    ".nuwax-agent",
    "agent-package.json",
    "template.manifest.json"
  ],
  "keywords": [
    "deepagents",
    "acp",
    "ai-agent",
    "langgraph",
    "nuwaclaw",
    "template"
  ],
  "license": "MIT"
}
