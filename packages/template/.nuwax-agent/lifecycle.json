{
  "$schema": "https://agent.nuwax.com/schemas/nuwax-agent-lifecycle.v1.json",
  "schemaVersion": "nuwax.agent.lifecycle.v1",
  "packageId": "deepagents-template",
  "install": {
    "modes": {
      "local": "Install from a local artifact (--artifact <path>)",
      "fromBucket": "Resolve the version from the MinIO/S3 bucket via the channel pointer (--from-bucket)"
    },
    "steps": [
      {
        "id": "verify-runtime",
        "type": "check",
        "command": "node --version"
      },
      {
        "id": "fetch-from-s3",
        "type": "s3-download",
        "condition": "fromBucket == true",
        "channel": "${CHANNEL}",
        "endpoint": "${NUWAX_S3_ENDPOINT}",
        "bucket": "${NUWAX_S3_BUCKET}",
        "prefix": "${PREFIX}",
        "outputArtifact": "${INSTALL_TMP}/${ARTIFACT_FILE}"
      },
      {
        "id": "verify-checksum",
        "type": "sha256-verify",
        "condition": "fromBucket == true",
        "checksumsPath": "${INSTALL_TMP}/package-checksums.json",
        "artifact": "${INSTALL_TMP}/${ARTIFACT_FILE}"
      },
      {
        "id": "materialize-placeholders",
        "type": "replace-placeholders",
        "config": ".nuwax-agent/placeholders.json"
      },
      {
        "id": "register-agent-server",
        "type": "write-config",
        "source": ".nuwax-agent/debug.agent_servers.example.json"
      },
      {
        "id": "create-log-dir",
        "type": "mkdir",
        "path": "${LOG_DIR}"
      }
    ]
  },
  "upgrade": {
    "strategy": "preserve-user-config",
    "modes": {
      "local": "Upgrade using a local artifact (--artifact <path>)",
      "fromBucket": "Pull the next version from the MinIO/S3 bucket via the channel pointer (--from-bucket)"
    },
    "preserve": [
      "config/*.local.json",
      ".env",
      "logs/**",
      "skills/platform/**"
    ],
    "steps": [
      {
        "id": "fetch-from-s3",
        "type": "s3-download",
        "condition": "fromBucket == true",
        "channel": "${CHANNEL}",
        "endpoint": "${NUWAX_S3_ENDPOINT}",
        "bucket": "${NUWAX_S3_BUCKET}",
        "prefix": "${PREFIX}",
        "outputArtifact": "${UPGRADE_TMP}/${ARTIFACT_FILE}"
      },
      {
        "id": "verify-checksum",
        "type": "sha256-verify",
        "condition": "fromBucket == true",
        "checksumsPath": "${UPGRADE_TMP}/package-checksums.json",
        "artifact": "${UPGRADE_TMP}/${ARTIFACT_FILE}"
      },
      {
        "id": "compare-versions",
        "type": "version-compare",
        "condition": "fromBucket == true",
        "currentPath": "${INSTALL_ROOT}/.nuwax-agent/install-state.json",
        "targetVersion": "${TARGET_VERSION}",
        "onSameVersion": "skip-with-message"
      },
      {
        "id": "backup-current",
        "type": "backup",
        "path": "${INSTALL_ROOT}"
      },
      {
        "id": "replace-versioned-files",
        "type": "sync-package-files"
      },
      {
        "id": "migrate-placeholders",
        "type": "replace-placeholders",
        "config": ".nuwax-agent/placeholders.json"
      },
      {
        "id": "verify-upgraded-agent",
        "type": "healthcheck",
        "command": "node ${INSTALL_ROOT}/dist/cli/index.js --version"
      }
    ]
  },
  "publish": {
    "description": "Upload packaged artifacts, metadata, scripts, and manifests to the MinIO/S3 bucket declared in distribution.json. Used by release pipelines and manual publishing.",
    "script": "scripts/publish-s3.sh",
    "config": ".nuwax-agent/distribution.json",
    "steps": [
      {
        "id": "verify-distribution-config",
        "type": "validate-config",
        "schema": "nuwax.agent.distribution.v1",
        "path": ".nuwax-agent/distribution.json"
      },
      {
        "id": "verify-artifacts-present",
        "type": "require-files",
        "patterns": [
          "dist-packages/deepagents-dev-templates-${VERSION}.tgz",
          "dist-packages/deepagents-dev-templates-${VERSION}-nuwax.tar.gz",
          "dist-packages/deepagents-dev-templates-${VERSION}-nuwax.zip",
          "dist-packages/deepagents-dev-templates-${VERSION}.version.json",
          "dist-packages/deepagents-dev-templates-${VERSION}.platform.json",
          "dist-packages/package-checksums.json",
          "dist-packages/agent-package.release.json"
        ]
      },
      {
        "id": "sync-versioned-prefix",
        "type": "s3-sync",
        "endpoint": "${NUWAX_S3_ENDPOINT}",
        "bucket": "${NUWAX_S3_BUCKET}",
        "destination": "engines/deepagents-app-ts/versions/${VERSION}/"
      },
      {
        "id": "update-channel-pointer",
        "type": "s3-put",
        "key": "engines/deepagents-app-ts/channels/${CHANNEL}.json",
        "cacheControl": "public, max-age=60, must-revalidate"
      },
      {
        "id": "update-latest-pointer",
        "type": "s3-put-conditional",
        "condition": "channel == 'stable'",
        "key": "engines/deepagents-app-ts/latest.json",
        "cacheControl": "public, max-age=60, must-revalidate"
      }
    ]
  },
  "release": {
    "description": "Tag-driven orchestrator that bumps nothing on its own. It assumes package.json and agent-package.json already match the supplied tag, then runs package.sh and publish-s3.sh back-to-back.",
    "script": "scripts/release.sh",
    "invocation": "bash scripts/release.sh <git-tag> [--allow-dirty] [--dry-run] [--skip-publish]",
    "tagPatterns": {
      "stable": "^v?\\d+\\.\\d+\\.\\d+$",
      "beta": "^v?\\d+\\.\\d+\\.\\d+-(alpha|beta|rc|preview|dev)\\.\\d+$"
    },
    "channelByTag": {
      "rule": "tag contains '-' → beta, otherwise → stable"
    },
    "prerequisites": [
      "Working tree clean (override with --allow-dirty)",
      "package.json.version == agent-package.json.version == tag (without leading 'v')"
    ]
  },
  "uninstall": {
    "strategy": "remove-package-preserve-export",
    "exportBeforeRemove": [
      "config/*.local.json",
      "skills/platform/**",
      "logs/**"
    ],
    "steps": [
      {
        "id": "stop-agent-server",
        "type": "stop-service",
        "service": "deepagents-template"
      },
      {
        "id": "export-user-data",
        "type": "archive",
        "output": "${WORKSPACE_ROOT}/deepagents-template-uninstall-export.zip"
      },
      {
        "id": "remove-package",
        "type": "remove",
        "path": "${INSTALL_ROOT}"
      }
    ]
  }
}

