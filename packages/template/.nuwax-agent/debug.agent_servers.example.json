{
  "agent_servers": {
    "deepagents-template": {
      "type": "custom",
      "command": "node",
      "args": [
        "--import",
        "tsx",
        "${TEMPLATE_ROOT}/src/index.ts"
      ],
      "env": {
        "OPENAI_MODEL": "${OPENAI_MODEL}",
        "OPENAI_BASE_URL": "${OPENAI_BASE_URL}",
        "OPENAI_API_KEY": "${SECRET_OPENAI_API_KEY}"
      }
    }
  }
}
