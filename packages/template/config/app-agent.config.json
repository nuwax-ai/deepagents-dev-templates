{
  "$schema": "./config-schema.json",
  "agent": {
    "name": "my-scenario-agent",
    "description": "AI agent for [specific scenario]",
    "version": "0.3.0",
    "outputStyle": "concise"
  },
  "model": {
    "provider": "anthropic",
    "name": "claude-sonnet-4-6",
    "settings": {
      "temperature": 0,
      "maxTokens": 16384
    }
  },
  "mcp": {
    "configPath": "./config/mcp.default.json",
    "mergeStrategy": "session-wins"
  },
  "platform": {
    "apiBaseUrl": "https://api.nuwax.com",
    "agentId": "",
    "spaceId": ""
  },
  "permissions": {
    "mode": "ask",
    "interruptOn": [
      "write_file",
      "edit_file",
      "execute"
    ],
    "allowedPaths": [
      "src/app/",
      "prompts/",
      "skills/",
      "config/"
    ],
    "deniedPaths": [
      "src/runtime/",
      "src/surfaces/"
    ]
  },
  "skills": {
    "directories": [
      "./skills/builtin/",
      "./skills/platform/"
    ],
    "progressiveLoading": true
  },
  "agentsDirectories": [
    "./.agents"
  ],
  "memory": {
    "enabled": true,
    "dir": "./.agent-memory",
    "addCacheControl": true
  },
  "logging": {
    "level": "info",
    "structured": true
  },
  "middleware": {
    "stuckLoopDetection": {
      "enabled": true,
      "threshold": 3,
      "mode": "warn"
    },
    "periodicReminder": {
      "enabled": true,
      "firstAt": 5,
      "every": 10
    },
    "costTracking": {
      "enabled": true,
      "warnAtTokens": 100000
    }
  }
}
