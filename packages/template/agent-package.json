{
  "name": "deepagents-app-agent",
  "version": "0.1.0",
  "description": "AI application agent built with DeepAgents + ACP",
  "engine": "deepagents-app",

  "source": {
    "type": "npm",
    "package": "deepagents-dev-templates",
    "registry": "https://registry.npmjs.org",
    "version": "0.1.0"
  },

  "alternativeSources": [
    {
      "type": "tgz",
      "path": "./deepagents-dev-templates-0.1.0.tgz",
      "version": "0.1.0"
    },
    {
      "type": "git",
      "url": "https://github.com/nuwax-ai/deepagents-dev-templates.git",
      "ref": "v0.1.0"
    }
  ],

  "bin": {
    "start": "dist/index.js",
    "graph": "dist/index.js graph"
  },

  "graph": {
    "schema": "nuwaclaw.agent-code-graph.v1",
    "command": "node dist/index.js graph",
    "description": "Generates the code node relationship graph for nuwaclaw UI rendering."
  },

  "env": {
    "required": [],
    "optional": [
      "ANTHROPIC_API_KEY",
      "ANTHROPIC_MODEL",
      "ANTHROPIC_BASE_URL",
      "ANTHROPIC_AUTH_TOKEN",
      "OPENAI_API_KEY",
      "PLATFORM_API_TOKEN",
      "PLATFORM_AGENT_ID",
      "PLATFORM_SPACE_ID",
      "ACP_SESSION_CONFIG_JSON"
    ],
    "oneOfRequired": [
      ["ANTHROPIC_API_KEY"],
      ["ANTHROPIC_AUTH_TOKEN"],
      ["OPENAI_API_KEY"]
    ]
  },

  "mcp": {
    "servers": [
      "context7"
    ]
  },

  "platform": {
    "agentId": "",
    "spaceId": "",
    "apiBaseUrl": "https://api.nuwax.com"
  },

  "checksum": {
    "algorithm": "sha256",
    "value": ""
  },

  "metadata": {
    "templateVersion": "1.0.0",
    "framework": "deepagents-js",
    "deepagentsVersion": "^1.10.2",
    "acpVersion": "latest",
    "nodeVersion": ">=20.0.0"
  }
}
