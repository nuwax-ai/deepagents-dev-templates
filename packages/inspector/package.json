{
  "name": "inspector",
  "version": "0.1.0",
  "description": "Read-only DeepAgents orchestration inspector and local visualizer.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "deepagents-inspect": "dist/cli/inspect.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "INSPECTOR_TEMPLATE_SOURCE=1 tsx src/cli/inspect.ts",
    "inspect": "INSPECTOR_TEMPLATE_SOURCE=1 tsx src/cli/inspect.ts",
    "test": "INSPECTOR_TEMPLATE_SOURCE=1 vitest run"
  },
  "dependencies": {
    "deepagents-app-ts": "file:../template"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
