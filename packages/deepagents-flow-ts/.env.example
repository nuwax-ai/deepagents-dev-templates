# 模型凭证 —— 与 `deepagents-app-ts/runtime` 环境变量约定一致。
# 本地 CLI（`pnpm flow`）测试时复制本文件为 `.env` 并填写；ACP 模式下凭证由宿主 env 注入。
# LLM 节点真调大模型、无 demo fallback，必须配下面之一才能跑 LLM 节点。

# ── 方式 A：OpenAI 兼容端点（默认；国内常用 DeepSeek / 通义千问 / 智谱 GLM / Kimi / 小米 mimo）──
# 默认 provider=openai（见 config/flow-agent.config.json）。国内端点把 OPENAI_BASE_URL 指向对应兼容地址：
#   DeepSeek   https://api.deepseek.com/v1                              模型 deepseek-chat（默认）
#   通义千问   https://dashscope.aliyuncs.com/compatible-mode/v1        模型 qwen-plus
#   智谱 GLM   https://open.bigmodel.cn/api/paas/v4                     模型 glm-4
#   Kimi       https://api.moonshot.cn/v1                               模型 moonshot-v1-8k
OPENAI_MODEL=deepseek-chat
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=

# ── 方式 B：Anthropic 协议 / 自托管代理（备选）──────────────
# 改用 Anthropic 时：将 config/flow-agent.config.json 的 model.provider 设为 "anthropic"，并留空上方 OPENAI_*。
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# ── 模型运行时（可选）────────────────────────────────────
# 覆盖 config 里 model.settings.maxTokens；不配则用 flow-agent.config.json 默认值。
MAX_TOKENS=16384
# LLM 调用韧性（模板 src/runtime/llm-resilience.ts；deep-research 实战反哺）
# LLM_TIMEOUT_MS=120000        # 短调用超时（think / plan / review / 章节摘要）
# LLM_LONG_TIMEOUT_MS=180000   # 长调用超时（draft / respond / compaction 摘要）
# LLM_MAX_CONCURRENT=2           # Send 并行时 LLM 最大并发

# ── MCP / 运行时 ────────────────────────────────────────
# 设为 disabled 可跳过默认 MCP server 加载（本地调试轻量验证；亦兼容 off/none；不影响 ACP session 下发的 MCP）
# 旧文档中的 AGENT_LIGHT=1 已废弃，请改用 DEEPAGENTS_DEFAULT_MCP=disabled
# DEEPAGENTS_DEFAULT_MCP=disabled
# MCP 工具调用超时（毫秒）
# MCP_TOOL_TIMEOUT_MS=30000

# ── 日志 ────────────────────────────────────────────────
# LOG_LEVEL debug|info|warn|error（默认 info）。debug 时日志不脱敏（展示完整凭证/端点/模型名），
#           其余级别对模型相关敏感字段（apiKey/secret/token/baseUrl/endpoint/model 名）脱敏。
# LOG_DIR   日志目录（默认 ~/.flowagents/logs；per-session 一个 agentName-sessionId-YYYY_MM_DD.log）。
#           留空用默认；设绝对/相对路径可覆盖（开发排查常用 `<项目根>/.logs`）。
LOG_LEVEL=debug
LOG_DIR=
