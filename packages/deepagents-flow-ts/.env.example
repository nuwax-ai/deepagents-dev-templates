# 模型凭证 —— 与 deepagents-app-ts 保持一致。
# ACP 模式下通常由 IDE host(Zed/JetBrains) 注入，本地 CLI 测试时才需要这里。
# 注：examples/（travel / project-manager / human-in-loop）真调大模型、无 demo fallback，必须配下面之一才能跑；
#     travel 的网络搜索走免 key 的 duckduckgo-mcp-server（npx 自动拉起，无需额外凭证）。

# 默认 provider=anthropic（见 config/flow-agent.config.json）
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=
# 自托管 / 代理端点时设置（指向你的网关）
ANTHROPIC_BASE_URL=

# 若改用 OpenAI 兼容端点（如 mimo）：把 config 的 model.provider 设为 "openai"、
# model.baseUrl 设为端点地址，并在此提供 key：
OPENAI_API_KEY=
OPENAI_BASE_URL=

# 日志
LOG_LEVEL=info
