# 模型凭证 —— 与 deepagents-app-ts 一致。
# ACP 模式下通常由 IDE host（Zed/JetBrains）注入；本地 CLI / smoke 测试时复制本文件为 .env 并填写。
# examples/ 与 dev-agent 真调大模型、无 demo fallback，必须配下面之一才能跑 LLM 节点。

# ── 方式 A：OpenAI 兼容端点（如小米 mimo）────────────────
# 使用 OPENAI_* 时，将 config/flow-agent.config.json 的 model.provider 设为 "openai"。
OPENAI_MODEL=
OPENAI_BASE_URL=
OPENAI_API_KEY=

# ── 方式 B：Anthropic 协议 / 自托管代理 ───────────────────
# 默认 provider=anthropic（见 config/flow-agent.config.json）；用此方式时留空上方 OPENAI_*。
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# ── 模型运行时（可选）────────────────────────────────────
# 覆盖 config 里 model.settings.maxTokens；不配则用 flow-agent.config.json 默认值。
MAX_TOKENS=16384

# ── nuwax 平台（acp-dynamic 能力层）────────────────────
# 配置后启用 platform_api 工具 + 平台绑定的 MCP 组件下发（见 capability-sources.json）
PLATFORM_AGENT_ID=
PLATFORM_SPACE_ID=
PLATFORM_API_TOKEN=

# ── MCP / 运行时 ────────────────────────────────────────
# 设为 disabled 可关闭默认 MCP（如不想拉起 context7）
# DEEPAGENTS_DEFAULT_MCP=disabled
# MCP 工具调用超时（毫秒）
# MCP_TOOL_TIMEOUT_MS=30000

# ── 日志 ────────────────────────────────────────────────
# LOG_DIR 建议指向 monorepo 根下的 .logs/（已在 .gitignore 内）
LOG_LEVEL=debug
LOG_DIR=
