{
  "flow": {
    "active": "default",
    "defaultInteraction": "chat",
    "unknownActivePolicy": "warn-default"
  },
  "agent": {
    "name": "nuwax-flow-ts",
    "description": "通用工作流编排模板 — Agent 按显式 LangGraph 节点图运行（默认 ReAct：prepare → think ↔ tools → respond）。工具/会话/压缩/Skills/Subagent 经本仓库 config 与能力分层驱动。",
    "version": "2.1.4",
    "outputStyle": "concise",
    "systemPromptPath": "prompts/flow.base.md",
    "includeWorkspaceInstructions": true
  },
  "model": {
    "provider": "openai",
    "name": "deepseek-v4-flash",
    "baseUrl": "https://api.deepseek.com/v1",
    "apiKeyEnv": "OPENAI_API_KEY",
    "settings": {
      "temperature": 0,
      "maxTokens": 16384
    }
  },
  "mcp": {
    "configPath": "./config/mcp.default.json",
    "mergeStrategy": "session-wins"
  },
  "permissions": {
    "mode": "ask",
    "interruptOn": [
      "write_file",
      "edit_file",
      "bash",
      "http_request"
    ],
    "allowedPaths": [
      "src/app/",
      "prompts/",
      "builtin/",
      "config/",
      ".agents/"
    ],
    "deniedPaths": [
      "src/runtime/",
      "src/surfaces/"
    ]
  },
  "sandbox": {
    "profile": "workspace-write",
    "writablePaths": [
      "src/app/",
      "prompts/",
      "builtin/",
      "config/",
      ".agents/"
    ],
    "deniedWritePaths": [
      "src/runtime/",
      "src/surfaces/"
    ]
  },
  "skills": {
    "directories": [],
    "progressiveLoading": true
  },
  "subagents": {
    "directories": []
  },
  "agentsDirectories": [
    "./builtin",
    "./.agents"
  ],
  "memory": {
    "enabled": true,
    "dir": "~/.flowagents",
    "addCacheControl": true
  },
  "logging": {
    "level": "info",
    "structured": true
  },
  "compaction": {
    "enabled": true,
    "contextWindow": 200000,
    "triggerThreshold": 0.8,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "middleware": {
    "stuckLoopDetection": {
      "enabled": true,
      "threshold": 3,
      "mode": "warn"
    },
    "periodicReminder": {
      "enabled": true,
      "firstAt": 5,
      "every": 10
    },
    "costTracking": {
      "enabled": true,
      "warnAtTokens": 100000
    }
  }
}
