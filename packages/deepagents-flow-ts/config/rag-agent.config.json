{
  "agent": {
    "name": "deepagents-flow-ts",
    "description": "RAG 工作流 agent — 按显式 LangGraph 节点图运行（rewrite → retrieve → grade → prepare → generate）",
    "version": "0.1.0"
  },
  "model": {
    "provider": "anthropic",
    "name": "claude-sonnet-4-6",
    "settings": {
      "temperature": 0,
      "maxTokens": 16384
    }
  },
  "rag": {
    "enabled": true,
    "retrievalTools": ["context7", "howtocook-mcp"],
    "mcpServers": {
      "howtocook-mcp": {
        "command": "npx",
        "args": ["-y", "howtocook-mcp"],
        "enabled": true
      },
      "context7": {
        "command": "npx",
        "args": ["-y", "@upstash/context7-mcp"],
        "enabled": true
      }
    },
    "rewrite": {
      "maxKeywords": 5,
      "intentCategories": ["factual", "how_to", "comparison", "latest", "explain"]
    },
    "retrieve": {
      "maxResults": 10,
      "timeout_ms": 10000,
      "retryCount": 1
    },
    "prepare": {
      "maxContextTokens": 4000,
      "deduplication": true,
      "sortByRelevance": true
    },
    "agent": {
      "streaming": true,
      "includeSources": true,
      "confidenceThreshold": 0.5
    }
  }
}
