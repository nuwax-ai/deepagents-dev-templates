{
  "name": "search-aggregator",
  "description": "四路并行联网检索 → 汇总。联网搜索须到平台查找并添加（dev-engineer-toolkit），再配置 searchMcp。",
  "topology": "custom",
  "systemPrompt": "",
  "tools": [],
  "params": {
    "state": {
      "query": { "type": "string" },
      "aspect": { "type": "string" },
      "findings": { "type": "string-array-append" },
      "output": { "type": "string" }
    },
    "nodes": {
      "gather": { "type": "passthrough", "params": { "write": "() => ({})" } },
      "research": {
        "type": "mcp-retrieval",
        "params": {
          "mcpServers": {},
          "retrieve": "(s) => searchMcp ? { server: 'search', tool: searchMcp.tool, args: { query: `${s.query} ${aspectSuffix[s.aspect]}`, count: 5 } } : null",
          "write": "(r, s) => ({ findings: [`${s.aspect}：${r.ok ? r.text.slice(0, 200) : '（未配置搜索源）'}`] })"
        }
      },
      "aggregate": {
        "type": "llm-stream",
        "params": {
          "prompt": "(s) => [new SystemMessage('把各维度联网搜索结果整理成简短摘要，按维度列出。'), new HumanMessage(s.findings.join(' / '))]",
          "write": "(r) => ({ output: r.text })"
        }
      }
    },
    "edges": [
      { "kind": "static", "from": "__start__", "to": "gather" },
      {
        "kind": "fanout",
        "from": "gather",
        "target": "research",
        "items": "() => ['overview', 'news', 'analysis', 'sources']",
        "input": "(item, s) => ({ aspect: item, query: s.query })"
      },
      { "kind": "static", "from": "research", "to": "aggregate" },
      { "kind": "static", "from": "aggregate", "to": "__end__" }
    ],
    "input": { "queryField": "query" },
    "result": { "answerField": "output" }
  }
}
