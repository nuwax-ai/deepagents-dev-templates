{
  "name": "translate-review",
  "description": "翻译草稿 → 人审 → 按意见定稿（节点级 custom 拓扑，重表达 human-in-loop）",
  "topology": "custom",
  "systemPrompt": "",
  "tools": [],
  "params": {
    "state": {
      "query": { "type": "string" },
      "draft": { "type": "string" },
      "feedback": { "type": "string" },
      "output": { "type": "string" }
    },
    "nodes": {
      "compose": {
        "type": "llm",
        "params": {
          "prompt": "(s) => [new SystemMessage('你是专业中英互译，只输出译文，不要解释。'), new HumanMessage(s.query)]",
          "write": "(r) => ({ draft: r.content.trim() })"
        }
      },
      "review": {
        "type": "approval",
        "params": {
          "question": "(s) => `译文草稿：${s.draft} —— 说修改意见，或回 ok 通过`",
          "write": "(feedback) => ({ feedback })"
        }
      },
      "finalize": {
        "type": "approval-finalize",
        "params": {
          "approvedOutput": "(s) => ({ output: `✅ 译文已通过：${s.draft}` })",
          "rejectedLlm": {
            "prompt": "(s) => [new SystemMessage('按意见改写译文，只输出成稿。'), new HumanMessage(`原译：${s.draft}；修改意见：${s.feedback}`)]",
            "write": "(r) => ({ output: `✏️ 已按意见修订：${r.content}` })"
          }
        }
      }
    },
    "edges": [
      { "kind": "static", "from": "__start__", "to": "compose" },
      { "kind": "static", "from": "compose", "to": "review" },
      { "kind": "static", "from": "review", "to": "finalize" },
      { "kind": "static", "from": "finalize", "to": "__end__" }
    ],
    "input": { "queryField": "query" },
    "result": { "answerField": "output" }
  }
}
