{
  "name": "deepagents-flow-ts",
  "version": "1.9.4",
  "description": "Flow / workflow-orchestration agent template — the agent runs an explicit LangGraph StateGraph (not a dynamic tool loop) over ACP. Self-contained runtime; MCP via @langchain/mcp-adapters. Ships 4 curated flows (default ReAct, platform-capability sample, streaming pipeline, LLM router) plus 8 topology building blocks.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./graph": {
      "types": "./dist/app/graph.d.ts",
      "import": "./dist/app/graph.js"
    },
    "./topology": {
      "types": "./dist/app/topology.d.ts",
      "import": "./dist/app/topology.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "deepagents-flow-ts": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist/",
    "dev": "tsx watch --tsconfig tsconfig.json src/index.ts",
    "start": "node dist/index.js",
    "start:acp": "tsx src/index.ts",
    "flow": "tsx src/index.ts flow",
    "graph": "tsx src/index.ts graph",
    "example": "node scripts/run-example.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json --noEmit",
    "test": "vitest run",
    "test:integration": "RUN_INTEGRATION=1 vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke-acp.mjs",
    "bundle": "node scripts/lib/bundle.mjs",
    "setup:tools": "node scripts/setup-win-tools.mjs",
    "check:tools": "node scripts/check-tools.mjs",
    "version:check": "node scripts/sync-version.mjs --check",
    "version:sync": "node scripts/sync-version.mjs",
    "version:preview": "node scripts/sync-version.mjs --dry-run",
    "package": "node scripts/sync-version.mjs --check && node scripts/package.mjs",
    "package:all": "node scripts/sync-version.mjs --check && node scripts/package.mjs --format all",
    "package:platforms": "node scripts/sync-version.mjs --check && node scripts/package-platforms.mjs",
    "validate:package": "node scripts/validate-package.mjs"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.4.1",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/openai": "^1.3.0",
    "@langchain/langgraph-checkpoint": "1.1.0",
    "@langchain/mcp-adapters": "^1.1.0",
    "deepagents": "^1.10.2",
    "langchain": "1.4.4",
    "yaml": "^2.9.0",
    "dotenv": "^16.4.0",
    "zod": "^3.25.76",
    "@agentclientprotocol/sdk": "^0.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bestzip": "2.2.5",
    "tsx": "^4.22.4",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "config",
    "scripts",
    ".nuwax-agent/agent-package.json"
  ],
  "keywords": [
    "deepagents",
    "langgraph",
    "rag",
    "workflow",
    "orchestration",
    "acp",
    "template"
  ],
  "license": "MIT"
}
