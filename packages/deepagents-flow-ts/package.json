{
  "name": "deepagents-flow-ts",
  "version": "0.1.0",
  "description": "Flow / workflow-orchestration agent template — the agent runs an explicit, designed LangGraph node graph (not a dynamic tool loop) over ACP. Reuses the deepagents-app-ts runtime. Ships a RAG flow (rewrite → retrieve → grade → prepare → generate) as the bundled example.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./graph": {
      "types": "./dist/app/graph.d.ts",
      "import": "./dist/app/graph.js"
    },
    "./topology": {
      "types": "./dist/app/topology.d.ts",
      "import": "./dist/app/topology.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "deepagents-flow-ts": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist/",
    "dev": "tsx watch --tsconfig tsconfig.json src/index.ts",
    "start": "node dist/index.js",
    "start:acp": "tsx src/index.ts",
    "flow": "tsx src/index.ts flow",
    "graph": "tsx src/index.ts graph",
    "example:rag": "tsx examples/rag/index.ts",
    "example:rag:cli": "tsx examples/rag/index.ts rag",
    "example:rag:interactive": "tsx examples/rag/index.ts rag -i",
    "example:review": "tsx examples/human-in-loop/index.ts review",
    "example:travel": "tsx examples/travel-planner/index.ts plan",
    "example:pm": "tsx examples/project-manager/index.ts plan",
    "example:dev-agent": "tsx examples/dev-agent/index.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:acp": "bash scripts/smoke-acp.sh",
    "smoke:rag": "AGENT_ENTRY=examples/rag/index.ts bash scripts/smoke-acp.sh",
    "smoke:travel": "AGENT_ENTRY=examples/travel-planner/index.ts bash scripts/smoke-acp.sh",
    "smoke:pm": "AGENT_ENTRY=examples/project-manager/index.ts bash scripts/smoke-acp.sh",
    "smoke:review": "AGENT_ENTRY=examples/human-in-loop/index.ts bash scripts/smoke-acp.sh",
    "bundle": "bash scripts/bundle.sh",
    "package": "bash scripts/package.sh",
    "package:all": "bash scripts/package.sh --format all",
    "package:nuwax": "bash scripts/package.sh --format all",
    "package:platforms": "bash scripts/package-platforms.sh",
    "validate:package": "bash scripts/validate-package.sh"
  },
  "dependencies": {
    "@langchain/core": "latest",
    "@langchain/langgraph": "latest",
    "deepagents-acp": "latest",
    "deepagents-app-ts": "workspace:*",
    "dotenv": "^16.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.4",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "config",
    "scripts",
    "agent-package.json"
  ],
  "keywords": [
    "deepagents",
    "langgraph",
    "rag",
    "workflow",
    "orchestration",
    "acp",
    "template"
  ],
  "license": "MIT"
}
