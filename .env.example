# ===========================================
# DeepAgents Dev Templates - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# --- Model Provider API Keys ---
# At least one is required for the agent to function
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Platform Configuration ---
# Nuwax platform API endpoint
PLATFORM_API_BASE_URL=https://api.nuwax.com
# Platform authentication token
PLATFORM_API_TOKEN=
# Agent and space identifiers
PLATFORM_AGENT_ID=
PLATFORM_SPACE_ID=

# --- ACP Server Configuration ---
# Agent name displayed in ACP clients
ACP_AGENT_NAME=my-scenario-agent
# Agent description
ACP_AGENT_DESCRIPTION=AI agent for [specific scenario]
# Enable debug mode (true/false)
ACP_DEBUG=false
# Workspace root directory (defaults to cwd)
# ACP_WORKSPACE_ROOT=

# --- Model Configuration ---
# Override default model (e.g., anthropic:claude-sonnet-4-6)
# DEFAULT_MODEL=

# --- MCP Configuration ---
# Path to additional MCP config file
# MCP_CONFIG_PATH=./config/mcp.custom.json

# --- Logging ---
# Log level: debug, info, warn, error
LOG_LEVEL=info
